DATABASE_URL=postgresql://user:password@localhost:5432/dbname
SESSION_SECRET=your-session-secret-key-min-32-chars

# AI Providers (Vercel AI SDK)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# CVCRM API (obrigatório para webhook e integração)
CVCRM_BASE_URL=https://lyxengenharia.cvcrm.com.br
CVCRM_EMAIL=your-cvcrm-email
CVCRM_TOKEN=your-cvcrm-api-token

# CVCRM Sync — quando true, envia mensagens e altera situação no CV automaticamente
CVCRM_SYNC_ENABLED=false
